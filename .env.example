# Environment Variables for Gamified Environmental Education Platform
# Copy this file to .env and update the values

# Django Settings
SECRET_KEY=your-secret-key-here-change-this-in-production-make-it-very-long-and-random
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (for production)
DB_NAME=ecolearn_db
DB_USER=ecolearn_user  
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=EcoLearn Platform <noreply@ecolearn.edu>

# Redis Configuration (for production)
REDIS_URL=redis://localhost:6379/1

# Security Settings (for production)
SECURE_SSL_REDIRECT=False

# Third-party API Keys
OPENAI_API_KEY=your-openai-api-key-for-ai-features
